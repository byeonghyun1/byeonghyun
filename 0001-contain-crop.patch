+// 투명 PNG의 콘텐츠 바운딩 박스 계산 (실제 픽셀이 있는 영역의 상하좌우 경계)
+function getContentBounds(img) {
+  const tmpCanvas = document.createElement('canvas');
+  tmpCanvas.width = img.width;
+  tmpCanvas.height = img.height;
+  const tmpCtx = tmpCanvas.getContext('2d');
+  tmpCtx.drawImage(img, 0, 0);
+  const data = tmpCtx.getImageData(0, 0, img.width, img.height).data;
+
+  let top = img.height, bottom = 0, left = img.width, right = 0;
+  const step = 2; // 성능을 위해 2px 간격 샘플링
+  for (let y = 0; y < img.height; y += step) {
+    for (let x = 0; x < img.width; x += step) {
+      const a = data[(y * img.width + x) * 4 + 3];
+      if (a > 10) {
+        if (y < top) top = y;
+        if (y > bottom) bottom = y;
+        if (x < left) left = x;
+        if (x > right) right = x;
+      }
+    }
+  }
+
+  if (top >= bottom) return { top: 0, bottom: img.height, left: 0, right: img.width, contentH: img.height, contentW: img.width };
+  return { top, bottom, left, right, contentH: bottom - top, contentW: right - left };
+}
