+    if (!res.ok) return null;
+    const data = await res.json();
+    state.calibrationCache[bannerId] = data.average || {};
+    return data.average || {};
+  } catch (e) {
+    return null;
+  }
+}
+
+// 다운로드 시 학습 데이터 저장 (서버에 POST)
+async function saveCalibration(bannerId) {
+  if (!state.imageUrl) return; // 이미지 없으면 저장 불필요
+  const autoVals = state.cropAutoValues[bannerId] || { autoScale: 1.0, autoOffsetY: 0 };
+
+  const t = getImageTransform(bannerId);
+  const finalScale = (t.mode === 'manual') ? t.scale : 1.0;
+  const finalOffsetY = (t.mode === 'manual') ? t.offset.y : 0;
+  const finalOffsetX = (t.mode === 'manual') ? t.offset.x : 0;
+
+  const sample = {
+    date: new Date().toISOString().split('T')[0],
+    fit_mode: state.imageFitMode,
+    auto_scale: autoVals.autoScale,
+    final_scale: finalScale,
+    auto_offset_y: Math.round(autoVals.autoOffsetY),
+    final_offset_y: Math.round(finalOffsetY + autoVals.autoOffsetY),
+    scale_delta: Math.round((finalScale - 1.0) * 10000) / 10000,
+    offset_y_delta: Math.round(finalOffsetY),
+    offset_x_delta: Math.round(finalOffsetX)
+  };
+
+  try {
+    const res = await fetch('/api/calibration', {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({ banner_id: bannerId, sample })
