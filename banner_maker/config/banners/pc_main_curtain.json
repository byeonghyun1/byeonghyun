  "auto_decision_rules": {
    "composition_rule": [
      { "if": "서브카피 없음", "then": "single_main (메인 단독 1줄, 72px Bold)" },
      { "if": "서브카피 있음 && 합계 ≤ 28자", "then": "horizontal_sub_main (가로 1줄, 둘 다 72px)" },
      { "if": "서브카피 있음 && 합계 > 28자", "then": "horizontal_sub_main (가로 1줄, 둘 다 64px)" }
    ],
    "font_weight_rule": { "main": "Bold (항상)", "sub": "Medium (항상)" },
    "position_rule": "맥락에 따라 메인/서브 좌우 위치 변경 가능"
  },

